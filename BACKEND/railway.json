{
  "build": {
    "builder": "NIXPACKS_NODE_BUILDER",
    "buildCommand": "npm install && npm run build",
    "nodeVersion": "20"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "startCommand": "node server.js",
    "healthCheckPath": "/api/health"
  }
}